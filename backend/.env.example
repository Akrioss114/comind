PORT=8787
ALLOWED_ORIGINS=*
BRAND_NAME=CoMind
BOOKING_URL=https://example.com/booking
PUBLIC_SITE_URL=https://example.com

# Email delivery via Resend
RESEND_API_KEY=
EMAIL_FROM=CoMind AI <noreply@example.com>

# Email delivery via SMTP (used if RESEND_API_KEY is empty)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=

# Bitrix24 inbound webhook base URL.
# Example: https://yourcompany.bitrix24.ru/rest/1/abcdef123456
BITRIX_WEBHOOK_BASE=
BITRIX_ASSIGNED_BY_ID=

# Optional Bitrix lead custom fields
BITRIX_FIELD_SCORE=
BITRIX_FIELD_LEVEL=
BITRIX_FIELD_SUMMARY=
BITRIX_FIELD_GOAL=
BITRIX_FIELD_INDUSTRY=
